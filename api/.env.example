# Drillly API — copy to .env and fill as needed

# DRILLLY_PORT=5213
# DRILLLY_DB=./data/drillly.db

# Optional: Study workspace root (defaults to repo parent when drillly lives under Study/)
# STUDY_ROOT=D:\Study

# LLM providers (leave empty to use mock parser)
TONGYI_API_KEY=
DEEPSEEK_API_KEY=
LLM_DEFAULT_PROVIDER=mock

# Local Ollama (word AI supplement)
# LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_MODEL=qwen2.5:7b

# Windows C/C++ runner
# MINGW_BIN=C:\msys64\ucrt64\bin
